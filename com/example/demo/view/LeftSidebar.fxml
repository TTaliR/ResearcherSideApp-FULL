<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="250.0" styleClass="sidebar" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo.controller.LeftSidebarController">
    <Label styleClass="sidebar-title" text="ResearcherSide" />

    <VBox spacing="8.0" styleClass="sidebar-nav">
        <ToggleButton fx:id="useCasesNavButton" styleClass="sidebar-nav-button" text="Use Cases" />
        <ToggleButton fx:id="UsersNavButton" styleClass="sidebar-nav-button" text="Users" />
    </VBox>

    <Separator />

    <VBox fx:id="useCasesSidebarPane" spacing="8.0" VBox.vgrow="ALWAYS">
        <Label styleClass="sidebar-section-title" text="Available Use Cases" />
        <ListView fx:id="useCaseListView" VBox.vgrow="ALWAYS" />
        <Button fx:id="addUseCaseButton" text="Add Use Case" styleClass="primary-button" onAction="#onAddUseCaseRequested" />
        <Label text="To receive feedback, follow the n8n side instructions in 'Vibration Orchastrator': create a new rule and assign it to a user." wrapText="true" styleClass="sidebar-muted-text" />
    </VBox>

    <VBox fx:id="UsersSidebarPane" spacing="8.0" visible="false" managed="false" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <Label styleClass="sidebar-section-title" text="Users List" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="addUserButton" styleClass="sidebar-user-settings-button">
                <graphic>
                    <ImageView fitHeight="22.0" fitWidth="22.0" preserveRatio="true">
                        <image>
                            <Image url="@../images/add-user.png" />
                        </image>
                    </ImageView>
                </graphic>
            </Button>
        </HBox>
        <Label text="Total Users:" styleClass="sidebar-muted-text" />
        <Label fx:id="UsersCountLabel" text="0" styleClass="sidebar-count" />
        <ListView fx:id="UsersSidebarList" VBox.vgrow="ALWAYS" />
        <Separator />
        <Label styleClass="sidebar-section-title" text="Assign Use Case" />
        <Label text="Selected User:" styleClass="sidebar-muted-text" />
        <Label fx:id="selectedUserForAssignmentLabel" text="-" styleClass="sidebar-user-value" style="-fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-font-weight: bold;" />
        <Label text="Current Use Case:" styleClass="sidebar-muted-text" />
        <Label fx:id="currentUserUseCaseLabel" text="-" styleClass="sidebar-value" style="-fx-text-fill: #e5e7eb; -fx-font-size: 12px;" />
        <Label text="Assign to:" styleClass="sidebar-muted-text" />
        <ComboBox fx:id="userUseCaseComboBox" promptText="Select use case" />
        <Button fx:id="assignUserUseCaseButton" text="Assign Use Case" styleClass="primary-button" onAction="#onAssignUserUseCase" />
    </VBox>

    <Separator />

</VBox>

